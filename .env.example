# Скопируйте в файл `.env` в корне проекта.
# В клиент попадают только переменные с префиксом VITE_ (см. https://vite.dev/guide/env-and-mode.html).

VITE_GITLAB_URL=https://gitlab.example.com
# VITE_GITLAB_TOKEN=glpat-xxxxxxxx  # попадёт в собранный JS — не публикуйте сборку с токеном
# VITE_GITLAB_USERNAME=myuser
# VITE_STATS_DATE_START=2026-01-01
# VITE_STATS_DATE_END=2026-01-31
